# Supabase — copy this file to .env.local and fill in from the Supabase dashboard
# Project settings → Data API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never expose to the browser). Only used by trusted server actions
# / route handlers that need to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Ornn — real compute forward-curve API
ORNN_API_KEY=
ORNN_BASE_URL=

# Datadog — set to `fixture` for synthetic data during the hackathon, `http` for real API
DATADOG_MODE=fixture
