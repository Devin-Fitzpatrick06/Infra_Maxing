# Supabase — copy this file to .env.local and fill in from the Supabase dashboard
# Project settings → Data API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never expose to the browser). Only used by trusted server actions
# / route handlers that need to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=
